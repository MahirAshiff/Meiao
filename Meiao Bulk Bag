                    </div>
                    <div class="flex justify-between">
                        <button onclick="changeStep(3)" class="bg-gray-200 hover:bg-gray-300 text-gray-800 px-6 py-3 rounded font-bold transition">Back</button>
                        <button onclick="submitForm()" class="bg-meiao-orange hover-bg-meiao-orange text-white px-8 py-3 rounded font-bold transition text-lg shadow-lg">Get Your Free Quote Now</button>
                    </div>
                </div>

                <div id="step-success" class="step-hidden text-center py-8">
                    <div class="text-6xl text-green-500 mb-4">&#10004;</div>
                    <h3 class="text-3xl font-bold text-meiao-blue mb-2">Request Received</h3>
                    <p class="text-gray-600 text-lg">Thank you. Our procurement specialists will review your requirements and contact you within 24 hours.</p>
                </div>

            </div>
        </div>
    </section>

    <footer class="bg-slate-900 text-gray-400 py-12 text-center border-t border-gray-800">
        <div class="max-w-7xl mx-auto px-4">
            <div class="flex justify-center space-x-6 mb-6">
                <span class="border border-gray-600 px-3 py-1 rounded text-sm">ISO 9001 Certified</span>
                <span class="border border-gray-600 px-3 py-1 rounded text-sm">UN Testing Compliant</span>
                <span class="border border-gray-600 px-3 py-1 rounded text-sm">BRC/HACCP Ready</span>
            </div>
            <p>&copy; 2026 Meiao Bulk Bag Ltd. All Rights Reserved. Global Industrial Packaging Solutions.</p>
        </div>
    </footer>

    <script>
        const productData = {
            standard: {
                title: "Standard FIBC Bags (Types A, B, C, D)",
                desc: "Versatile, heavy-duty packaging for general industrial use. Engineered for a wide variety of dry flowable goods.",
                features: ["&#10004; 100% Virgin PP Material", "&#10004; U-Panel or Circular Woven options", "&#10004; UV treated for outdoor storage", "&#10004; Fully customizable dimensions"],
                swl: "500kg - 2500kg",
                sf: "5:1 (Single) / 6:1 (Multi)",
                fabric: "130gsm - 220gsm",
                uses: "Construction, Mining, Resins"
            },
            food: {
                title: "Premium Food-Grade FIBC Bulk Bags",
                desc: "Manufactured in our state-of-the-art, BRC-certified cleanrooms, our food-grade jumbo bags guarantee 100% safety for agricultural and consumable products. No contamination, no compromises.",
                features: ["&#10004; Produced in strict cleanroom environments", "&#10004; Ultrasonic cutting to prevent loose threads", "&#10004; Vacuumed and metal-detected", "&#10004; 100% food-safe virgin PP"],
                swl: "500kg - 2000kg",
                sf: "5:1 or 6:1",
                fabric: "130gsm - 220gsm (Customizable)",
                uses: "Flour, Sugar, Rice, Spices"
            },
            un: {
                title: "UN-Certified Hazardous Material Bags",
                desc: "Rigorously tested and certified for the safe transport of hazardous materials. Compliance you can trust when safety is not optional.",
                features: ["&#10004; Passes rigorous drop & tear tests", "&#10004; Meets international UN transport regulations", "&#10004; Anti-static (Type C/D) options available", "&#10004; Leak-proof inner liners"],
                swl: "Up to 2000kg",
                sf: "6:1 Mandatory",
                fabric: "Heavy Duty 180gsm+",
                uses: "Chemicals, Toxic Powders"
            },
            vent: {
                title: "Ventilated Agricultural Bags",
                desc: "Breathable fabrics perfect for agricultural products. Prevents moisture buildup and spoilage during transit.",
                features: ["&#10004; Woven with specialized breathable strips", "&#10004; Maintains product freshness", "&#10004; Strong enough for heavy root crops", "&#10004; High UV protection for field use"],
                swl: "1000kg - 1500kg",
                sf: "5:1",
                fabric: "Ventilated PP Mesh",
                uses: "Potatoes, Onions, Logs"
            }
        };

        const buttons = {
            standard: document.getElementById('btn-standard'),
            food: document.getElementById('btn-food'),
            un: document.getElementById('btn-un'),
            vent: document.getElementById('btn-vent')
        };

        function resetButtons() {
            Object.values(buttons).forEach(btn => {
                btn.className = "w-full text-left p-4 rounded border-2 border-gray-200 bg-white text-meiao-blue hover:border-meiao-orange font-bold text-lg transition shadow-sm";
            });
        }

        function updateProductDisplay(type) {
            resetButtons();
            const activeBtn = buttons[type];
            activeBtn.className = "w-full text-left p-4 rounded border-2 border-meiao-blue bg-meiao-blue text-white font-bold text-lg transition shadow-md";
            
            const data = productData[type];
            
            const display = document.getElementById('product-display');
            display.classList.remove('fade-in');
            void display.offsetWidth; 
            display.classList.add('fade-in');

            document.getElementById('display-title').innerText = data.title;
            document.getElementById('display-desc').innerText = data.desc;
            
            const featuresList = document.getElementById('display-features');
            featuresList.innerHTML = '';
            data.features.forEach(f => {
                let li = document.createElement('li');
                li.innerHTML = f;
                featuresList.appendChild(li);
            });

            document.getElementById('display-swl').innerText = data.swl;
            document.getElementById('display-sf').innerText = data.sf;
            document.getElementById('display-fabric').innerText = data.fabric;
            document.getElementById('display-uses').innerText = data.uses;
        }

        buttons.standard.addEventListener('click', () => updateProductDisplay('standard'));
        buttons.food.addEventListener('click', () => updateProductDisplay('food'));
        buttons.un.addEventListener('click', () => updateProductDisplay('un'));
        buttons.vent.addEventListener('click', () => updateProductDisplay('vent'));

        function changeStep(stepNum) {
            document.getElementById('step-1').className = 'step-hidden';
            document.getElementById('step-2').className = 'step-hidden';
            document.getElementById('step-3').className = 'step-hidden';
            document.getElementById('step-4').className = 'step-hidden';
            
            document.getElementById('step-' + stepNum).className = 'step-active';

            for(let i=1; i<=4; i++) {
                let tracker = document.getElementById('tracker-' + i);
                if(i < stepNum) {
                    tracker.className = "font-bold text-meiao-blue";
                } else if (i === stepNum) {
                    tracker.className = "font-bold text-meiao-orange";
                } else {
                    tracker.className = "font-bold text-gray-400";
                }
            }
        }

        function submitForm() {
            document.getElementById('step-4').className = 'step-hidden';
            document.getElementById('step-success').className = 'step-active';
            for(let i=1; i<=4; i++) {
                document.getElementById('tracker-' + i).className = "font-bold text-meiao-blue";
            }
        }

        document.addEventListener('DOMContentLoaded', function() {
            const ctx = document.getElementById('exportChart').getContext('2d');
            new Chart(ctx, {
                type: 'doughnut',
                data: {
                    labels: ['North America', 'Europe', 'Middle East', 'Asia & Others'],
                    datasets: [{
                        data: [40, 35, 15, 10],
                        backgroundColor: [
                            '#FF6B00',
                            '#0A2540',
                            '#9CA3AF',
                            '#E5E7EB'
                        ],
                        borderWidth: 0,
                        hoverOffset: 4
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: {
                            display: false
                        },
                        tooltip: {
                            callbacks: {
                                label: function(context) {
                                    return ' ' + context.label + ': ' + context.parsed + '% of Export Volume';
                                }
                            }
                        }
                    },
                    cutout: '70%'
                }
            });
        });
    </script>
</body>
</html>
